[0.043208, "o", "\r\n\u001b[1;36mACT 1 — WONDER   (~2 min)   The record, and what anyone can do with it.\u001b[0m\r\n\u001b[0;33m  “This is a model I trained. I'm not going to show you the code yet.”\u001b[0m\r\n\u001b[0;33m  “I'm going to show you its hash. This model IS this hash.”\u001b[0m\r\n\r\n\u001b[1;37m  2910820919f3fe354176189be8205cae796828809dd218eba3c2ea294055f51b\u001b[0m\r\n\r\n"]
[3.051887, "o", "\u001b[0;33m  “That hash isn't a checksum. It dereferences. Here's the whole record.”\u001b[0m\r\n\u001b[0;33m  “Inputs, git commit, environment, packages, timing, exit status.”\u001b[0m\r\n"]
[3.052403, "o", "\r\n\u001b[1;32m$ roar show 2910820919f3\u001b[0m\r\n"]
