[40.662658, "o", "\r\n\u001b[1;32m  ██  IDENTICAL  ██\u001b[0m\r\n\r\n"]
[43.67223, "o", "\u001b[0;33m  “Same hash. Bit for bit. That is what dereferenceable means.”\u001b[0m\r\n"]
[43.672684, "o", "\r\n"]
[46.686222, "o", "\r\n\u001b[1;36mACT 2 — THE REVEAL   (~30 sec)   The kicker.\u001b[0m\r\n"]
[46.686696, "o", "\u001b[0;33m  “Everything you just watched came from typing this in front of my”\u001b[0m\r\n\u001b[0;33m  “training command. No config. No instrumentation. No pipeline file.”\u001b[0m\r\n\r\n\u001b[1;37m  $ roar run python train.py\u001b[0m\r\n\r\n"]
[49.702743, "o", "\u001b[0;33m  “That's it. That's the whole integration. It was free.”\u001b[0m\r\n\r\n"]
[52.712302, "o", "\r\n\u001b[1;36mACT 3 — PAYOFF   (~2 min)   The record surfaces what I never declared.\u001b[0m\r\n"]
[52.712608, "o", "\u001b[0;33m  “One human act. I marked the raw dataset as containing personal data.”\u001b[0m\r\n\r\n\u001b[1;32m$ roar tag show data/raw.csv\u001b[0m\r\n"]
[53.266337, "o", "Tags on data/raw.csv:\r\n  contains_pii=present\r\n"]
[53.309599, "o", "\r\n"]
[56.320389, "o", "\u001b[0;33m  “I never said anything about the other files. Watch where it went.”\u001b[0m\r\n\r\n\u001b[1;32m$ python taint.py\u001b[0m\r\n"]
[57.015378, "o", "\r\n  \u001b[1mBLAST RADIUS\u001b[0m   contains_pii   ·   session 2\r\n\r\n  \u001b[2m@1\u001b[0m generate\r\n"]
[57.200647, "o", "       \u001b[1;31m●\u001b[0m data/raw.csv              \u001b[1;31mcontains_pii=present    \u001b[0m\u001b[2m← tagged here\u001b[0m\r\n"]
[57.655927, "o", "  \u001b[2m@2\u001b[0m preprocess\r\n"]
[57.838224, "o", "       \u001b[1;31m●\u001b[0m data/test.csv             \u001b[1;31mcontains_pii=present    \u001b[0m\u001b[2minherited\u001b[0m\r\n"]
[58.293567, "o", "       \u001b[1;31m●\u001b[0m data/train.csv            \u001b[1;31mcontains_pii=present    \u001b[0m\u001b[2minherited\u001b[0m\r\n"]
[58.745742, "o", "  \u001b[2m@3\u001b[0m train\r\n"]
[58.929211, "o", "       \u001b[1;31m●\u001b[0m model.pkl                 \u001b[1;31mcontains_pii=present    \u001b[0m\u001b[2minherited\u001b[0m\r\n"]
[59.384205, "o", "  \u001b[2m@4\u001b[0m evaluate\r\n"]
[59.569479, "o", "       \u001b[1;31m●\u001b[0m metrics.json              \u001b[1;31mcontains_pii=present    \u001b[0m\u001b[2minherited\u001b[0m\r\n"]
[60.024641, "o", "\r\n  \u001b[1;31m\u001b[1m5 of 5 artifacts carry contains_pii\u001b[0m\r\n  \u001b[2mnobody declared this. it followed the data.\u001b[0m\r\n\r\n"]
[60.034765, "o", "\r\n"]
[63.045775, "o", "\u001b[0;33m  “Five artifacts. One declaration. The tag followed the data, not a config.”\u001b[0m\r\n"]
[63.045891, "o", "\u001b[0;33m  “That's a blast radius — and it's the answer to 'which models are affected?'”\u001b[0m\r\n\r\n"]
[66.060173, "o", "\u001b[0;33m  “And it's not a guess. Ask the model why it's tainted, and it shows its work.”\u001b[0m\r\n"]
[66.060541, "o", "\r\n\u001b[1;32m$ roar tag why contains_pii model.pkl\u001b[0m\r\n"]
[66.482053, "o", "Why does model.pkl have contains_pii?\r\n  model.pkl: contains_pii=present — inherited via job 5fd99a3e\r\n      └─ test.csv: contains_pii=present — inherited via job 4afbeb02\r\n          └─ raw.csv: contains_pii=present — user `roar run --add-tag` in job 5b78cd2f (session-scoped)\r\n      └─ train.csv: contains_pii=present — inherited via job 4afbeb02\r\n          └─ raw.csv: contains_pii=present — user `roar run --add-tag` in job 5b78cd2f (session-scoped)\r\n"]
[66.522138, "o", "\r\n"]
