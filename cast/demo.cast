[0.023137, "o", "\r\n\u001b[1;36mACT 1 — WONDER   (~2 min)   The record, and what anyone can do with it.\u001b[0m\r\n\u001b[0;33m  “That was a bare file — no repo, no context. I hashed it and looked it up.”\u001b[0m\r\n\u001b[0;33m  “This model IS this hash. Now, back in the project, here's what it unfolds to.”\u001b[0m\r\n\r\n\u001b[1;37m  f91cc1f19ee45b8e91e12b8def84e976113db0ee39734ac75203bad40a5c5ec2\u001b[0m\r\n\r\n"]
[3.03016, "o", "\u001b[0;33m  “That hash isn't a checksum. It dereferences. Here's the whole record.”\u001b[0m\r\n\u001b[0;33m  “Inputs, git commit, environment, packages, timing, exit status.”\u001b[0m\r\n"]
