[49.670665, "o", "\r\n  \u001b[1;31m\u001b[1m5 of 5 artifacts carry contains_pii\u001b[0m\r\n  \u001b[2mnobody declared this. it followed the data.\u001b[0m\r\n\r\n"]
[49.682586, "o", "\r\n"]
[52.694872, "o", "\u001b[0;33m  “Five artifacts. One declaration. The tag followed the data, not a config.”\u001b[0m\r\n"]
[52.695131, "o", "\u001b[0;33m  “That's a blast radius — and it's the answer to 'which models are affected?'”\u001b[0m\r\n\r\n"]
[55.705136, "o", "\u001b[0;33m  “And it's not a guess. Ask the model why it's tainted, and it shows its work.”\u001b[0m\r\n\r\n\u001b[1;32m$ roar tag why contains_pii model.pkl\u001b[0m\r\n"]
