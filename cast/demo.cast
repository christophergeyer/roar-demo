[36.838089, "o", "\r\n\u001b[1;36mACT 2 — THE REVEAL   (~30 sec)   The kicker.\u001b[0m\r\n"]
[36.838256, "o", "\u001b[0;33m  “Everything you just watched came from typing this in front of my”\u001b[0m\r\n\u001b[0;33m  “training command. No config. No instrumentation. No pipeline file.”\u001b[0m\r\n\r\n\u001b[1;37m  $ roar run python train.py\u001b[0m\r\n"]
[36.838607, "o", "\r\n"]
[39.848835, "o", "\u001b[0;33m  “That's it. That's the whole integration. It was free.”\u001b[0m\r\n"]
[39.849159, "o", "\r\n"]
[42.862227, "o", "\r\n\u001b[1;36mACT 3 — PAYOFF   (~2 min)   The record surfaces what I never declared.\u001b[0m\r\n"]
[42.862645, "o", "\u001b[0;33m  “One human act. I marked the raw dataset as containing personal data.”\u001b[0m\r\n\r\n\u001b[1;32m$ roar tag show data/raw.csv\u001b[0m\r\n"]
[43.189962, "o", "Tags on data/raw.csv:\r\n  contains_pii=present\r\n"]
[43.215254, "o", "\r\n"]
[46.222089, "o", "\u001b[0;33m  “I never said anything about the other files. Watch where it went.”\u001b[0m\r\n"]
[46.222399, "o", "\r\n\u001b[1;32m$ python taint.py\u001b[0m\r\n"]
[46.661662, "o", "\r\n  \u001b[1mBLAST RADIUS\u001b[0m   contains_pii   ·   session 2\r\n\r\n  \u001b[2m@1\u001b[0m generate\r\n"]
