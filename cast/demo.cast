[3.06512, "o", "\u001b[0;33m  “That hash isn't a checksum. It dereferences. Here's the whole record.”\u001b[0m\r\n\u001b[0;33m  “Inputs, git commit, environment, packages, timing, exit status.”\u001b[0m\r\n"]
[3.065768, "o", "\r\n\u001b[1;32m$ roar show eaa6f5c6ea15\u001b[0m\r\n"]
